# Production environment for poukmaranatha
# Install at: /etc/poukmaranatha.env  (root:poukmaranatha 640)
# Loaded by the systemd unit via EnvironmentFile=

# Settings module — must be prod for HTTPS redirect, security headers, etc.
DJANGO_SETTINGS_MODULE=config.settings.prod

# Generate a fresh one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-me-with-a-real-secret

# Must be False in production. Setting True here disables every security header.
DJANGO_DEBUG=False

# Comma-separated. Add staging hostnames if you ever set them up.
DJANGO_ALLOWED_HOSTS=poukmaranatha.ionyx.org

# Postgres connection. The role + db are created during fresh install.
DATABASE_URL=postgres://poukmaranatha:CHANGE_ME@127.0.0.1:5432/poukmaranatha

# django-tailwind needs the absolute path to npm on Linux (default `npm.cmd` is Windows).
NPM_BIN_PATH=/usr/bin/npm

# Seed-superusers passwords (consumed by `manage.py seed_superusers`).
# Safe to leave here — only root + the service user can read this file.
DJANGO_SUPERUSER_AAMSA_PASSWORD=poer123
DJANGO_SUPERUSER_YOSUA_PASSWORD=theking0wfar
